# === Required: Twilio ===

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+12223334444

# Public URL where Twilio can reach your WebSocket and webhooks
# (e.g. https://your-domain.com or ngrok URL)
WEBHOOK_URL=https://your-domain.com

# === Lemonade (local AI) ===

LEMONADE_URL=http://127.0.0.1:8000/api/v1
STT_MODEL=Whisper-Large-v3-Turbo
TTS_MODEL=kokoro-v1
TTS_VOICE=af_heart
LLM_MODEL=Qwen3.5-4B-GGUF

# === Optional: LLM override ===
# If set, conversation LLM uses this instead of Lemonade
LLM_BASE_URL=
LLM_API_KEY=

# Optional: separate LLM for journal summarization
SUMMARIZE_LLM_BASE_URL=
SUMMARIZE_LLM_API_KEY=
SUMMARIZE_MODEL=

# === Voice activity detection ===

SILENCE_THRESHOLD_MS=1500

# === Single-User Quick Start ===
# Set these to auto-create a default user without editing users.json

PHONE_NUMBER=+15551234567
CALL_TIME=20:00
TIMEZONE=America/Denver
CONVERSATION_STYLE=casual

# === People ===
# Comma-separated names the user frequently mentions, with optional relationship
# Helps STT and journal generation get spellings right
# Example: Tearsa (wife, STT often hears: Kersa, Carissa), Taiah (daughter, STT often hears: Taya)
KNOWN_NAMES=

# === Security ===

# API key for /trigger endpoints (optional — if unset, no auth required)
API_KEY=

# === Server ===

PORT=3000
DATA_DIR=./data
